<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>STRECH — Gaming Hub</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg:       #0a0812;
  --bg2:      #0e0b1a;
  --surface:  #160f2a;
  --surface2: #1d1438;
  --border:   #2a1f4a;
  --accent:   #7c3aed;
  --accent2:  #a855f7;
  --accent3:  #c084fc;
  --green:    #22c55e;
  --text:     #e2e8f0;
  --text2:    #94a3b8;
  --text3:    #64748b;
  --radius:   10px;
  --radius-lg:16px;
  --trans:    0.2s cubic-bezier(0.4,0,0.2,1);
}
*{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--text);font-family:'Inter',sans-serif;font-size:15px;line-height:1.7;min-height:100vh;}
a{text-decoration:none;color:inherit;}
button{font-family:inherit;border:none;background:none;cursor:pointer;}

::-webkit-scrollbar{width:6px;height:6px;}
::-webkit-scrollbar-track{background:var(--bg);}
::-webkit-scrollbar-thumb{background:#2a1f4a;border-radius:10px;}
::-webkit-scrollbar-thumb:hover{background:#3a2a6a;}
*{scrollbar-width:thin;scrollbar-color:#2a1f4a var(--bg);}

/* LOADER */
#loader{position:fixed;inset:0;background:var(--bg);display:flex;align-items:center;justify-content:center;z-index:9999;transition:opacity 0.5s ease,visibility 0.5s;}
#loader.gone{opacity:0;visibility:hidden;pointer-events:none;}
.ld-inner{text-align:center;}
.ld-logo{font-family:'Syne',sans-serif;font-size:1.6rem;font-weight:800;letter-spacing:0.1em;color:#fff;margin-bottom:10px;}
.ld-logo span{color:var(--accent2);}
.ld-sub{font-family:'JetBrains Mono',monospace;font-size:0.6rem;letter-spacing:0.25em;color:var(--text3);text-transform:uppercase;margin-bottom:32px;}
.ld-bar-wrap{width:260px;height:2px;background:rgba(255,255,255,0.06);border-radius:2px;overflow:hidden;margin:0 auto 14px;}
.ld-bar{height:100%;width:0%;background:linear-gradient(90deg,var(--accent),var(--accent2),var(--accent3));transition:width 0.1s linear;box-shadow:0 0 8px rgba(168,85,247,0.6);}
.ld-msg{font-family:'JetBrains Mono',monospace;font-size:0.62rem;letter-spacing:0.25em;color:var(--text3);text-transform:uppercase;}

/* SIDEBAR */
#sidebar{position:fixed;top:0;left:0;width:260px;height:100vh;background:var(--bg2);border-right:1px solid var(--border);display:flex;flex-direction:column;z-index:200;overflow-y:auto;transition:transform var(--trans);}
#sidebar::-webkit-scrollbar{width:4px;}
#sidebar::-webkit-scrollbar-thumb{background:var(--border);border-radius:4px;}

.sb-logo{padding:26px 22px 20px;border-bottom:1px solid var(--border);cursor:pointer;transition:background var(--trans);flex-shrink:0;}
.sb-logo:hover{background:var(--surface);}
.sb-logo-main{font-family:'Syne',sans-serif;font-size:22px;font-weight:800;letter-spacing:-0.5px;color:#fff;line-height:1;}
.sb-logo-main span{color:var(--accent2);}
.sb-logo-sub{font-size:10.5px;font-family:'JetBrains Mono',monospace;color:var(--text3);letter-spacing:2px;margin-top:6px;text-transform:uppercase;}

.sb-nav-btn{display:flex;align-items:center;gap:10px;padding:11px 22px;font-size:13px;font-weight:500;color:var(--text2);cursor:pointer;border-left:2px solid transparent;transition:all var(--trans);}
.sb-nav-btn:hover{color:var(--text);background:var(--surface);}
.sb-nav-btn.active{color:#fff;border-left-color:var(--accent2);background:rgba(124,58,237,0.1);}
.sb-nav-btn.active svg{opacity:1;}
.sb-nav-btn svg{width:14px;height:14px;opacity:0.6;flex-shrink:0;}
.sb-nav-btn.border-b{border-bottom:1px solid var(--border);}

.sb-section-title{font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--text3);padding:18px 22px 8px;flex-shrink:0;}
.sb-section-title.purple{color:var(--accent3);}

.sb-link{display:flex;align-items:center;gap:10px;padding:8px 22px;font-size:13px;color:var(--text2);border-left:2px solid transparent;transition:all var(--trans);cursor:pointer;flex-shrink:0;}
.sb-link:hover{color:var(--text);background:var(--surface);}
.sb-link.hl{color:var(--accent3);border-left-color:var(--accent2);background:rgba(124,58,237,0.08);}
.sb-link svg{width:13px;height:13px;opacity:0.45;flex-shrink:0;}

.sb-divider{height:1px;background:var(--border);margin:8px 0;flex-shrink:0;}

/* SIDEBAR SEARCH */
.sb-search{padding:10px 14px;border-bottom:1px solid var(--border);flex-shrink:0;}
.sb-search-inner{display:flex;align-items:center;gap:8px;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:7px 12px;transition:border-color var(--trans);}
.sb-search-inner:focus-within{border-color:var(--accent2);}
.sb-search-inner svg{width:13px;height:13px;color:var(--text3);flex-shrink:0;}
#sb-search-input{background:none;border:none;outline:none;font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--text);width:100%;caret-color:var(--accent2);}
#sb-search-input::placeholder{color:var(--text3);}

/* TODOS GRID */
.todos-grid{display:flex;flex-direction:column;gap:12px;}
.todos-game-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-lg);padding:20px 22px;display:flex;align-items:center;gap:18px;cursor:pointer;transition:all var(--trans);position:relative;overflow:hidden;}
.todos-game-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--accent),var(--accent2));opacity:0;transition:opacity var(--trans);}
.todos-game-card:hover{border-color:rgba(124,58,237,0.4);transform:translateX(4px);background:var(--surface);}
.todos-game-card:hover::before{opacity:1;}
.todos-game-card.hidden-search{display:none;}
.todos-card-icon{width:52px;height:52px;border-radius:12px;background:rgba(124,58,237,0.12);border:1px solid rgba(124,58,237,0.25);display:flex;align-items:center;justify-content:center;color:var(--accent2);flex-shrink:0;}
.todos-card-icon svg{width:22px;height:22px;}
.todos-card-content{flex:1;min-width:0;}
.todos-card-title{font-family:'Syne',sans-serif;font-size:17px;font-weight:800;color:#fff;margin-bottom:3px;}
.todos-card-sub{font-size:12px;color:var(--text3);font-family:'JetBrains Mono',monospace;margin-bottom:10px;}
.todos-card-tags{display:flex;gap:6px;flex-wrap:wrap;}
.todos-card-arrow{color:var(--text3);flex-shrink:0;transition:transform var(--trans),color var(--trans);}
.todos-card-arrow svg{width:16px;height:16px;}
.todos-game-card:hover .todos-card-arrow{transform:translateX(4px);color:var(--accent2);}

/* TODOS CATEGORY (sidebar old - unused now) */
.todos-category{display:none;}
.sb-bottom{margin-top:auto;padding:16px 22px;border-top:1px solid var(--border);flex-shrink:0;}
.sb-version{font-size:10px;font-family:'JetBrains Mono',monospace;color:var(--text3);letter-spacing:0.1em;}
.sb-back-btn{display:flex;align-items:center;gap:8px;padding:10px 14px;border-radius:var(--radius);background:rgba(124,58,237,0.08);border:1px solid rgba(124,58,237,0.2);color:var(--accent3);font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:600;letter-spacing:0.05em;text-decoration:none;transition:all var(--trans);cursor:pointer;}
.sb-back-btn:hover{background:rgba(124,58,237,0.18);border-color:rgba(124,58,237,0.45);color:#fff;transform:translateX(-2px);}

/* MAIN */
#main{margin-left:260px;min-height:100vh;}
#topbar{position:sticky;top:0;z-index:100;background:rgba(10,8,18,0.92);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);padding:0 40px;height:54px;display:flex;align-items:center;justify-content:space-between;}
.tb-bc{font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--text3);}
.tb-bc .tb-sep{color:var(--text3);margin:0 6px;}
.tb-bc .tb-page{color:var(--accent2);}
#hamburger{display:none;color:var(--text);padding:6px;}

/* PAGES */
.page{display:none;animation:fadeIn 0.22s ease;}
.page.active{display:block;}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
#content{padding:48px 54px;max-width:940px;}

/* HOME HERO */
.home-hero{padding:48px 0 52px;border-bottom:1px solid var(--border);margin-bottom:40px;position:relative;}
.home-hero::before{content:'';position:absolute;top:0;left:-54px;right:-54px;bottom:0;background:radial-gradient(ellipse 60% 50% at 80% 50%,rgba(124,58,237,0.06) 0%,transparent 70%);pointer-events:none;}
.home-eyebrow{font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:3px;text-transform:uppercase;color:var(--accent2);margin-bottom:20px;display:flex;align-items:center;gap:8px;}
.home-eyebrow .dot{width:6px;height:6px;border-radius:50%;background:var(--green);box-shadow:0 0 8px rgba(34,197,94,0.8);animation:blink 1.6s ease-in-out infinite;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0.3}}
.home-hero h1{font-family:'Syne',sans-serif;font-size:clamp(44px,6vw,68px);font-weight:800;letter-spacing:-2px;line-height:0.95;color:#fff;margin-bottom:6px;}
.home-hero h1 em{color:var(--accent2);font-style:normal;}
.home-subtitle{font-size:15px;color:var(--text2);font-weight:300;margin-top:20px;max-width:540px;line-height:1.65;margin-bottom:28px;}
.home-actions{display:flex;gap:12px;flex-wrap:wrap;}
.btn-primary{display:inline-flex;align-items:center;gap:8px;padding:10px 22px;border-radius:var(--radius);background:linear-gradient(135deg,var(--accent),var(--accent2));color:#fff;font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600;letter-spacing:0.1em;cursor:pointer;transition:all var(--trans);box-shadow:0 4px 20px rgba(124,58,237,0.35);}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 6px 30px rgba(124,58,237,0.55);}
.btn-primary svg{width:14px;height:14px;}

/* ABOUT SECTION (dentro de home) */
.about-section{margin-top:52px;padding-top:40px;}
.about-section-title{font-family:'Syne',sans-serif;font-size:24px;font-weight:800;color:#fff;margin-bottom:6px;letter-spacing:-0.5px;}
.about-section-title em{color:var(--accent2);font-style:normal;}
.about-section-sub{font-size:13.5px;color:var(--text2);margin-bottom:26px;}
.about-cards{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:22px;}
.about-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-lg);padding:22px;transition:all var(--trans);}
.about-card:hover{border-color:rgba(124,58,237,0.35);transform:translateY(-2px);}
.about-card-icon{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;margin-bottom:12px;}
.about-card-icon.purple{background:rgba(124,58,237,0.15);color:var(--accent2);}
.about-card-icon.pink{background:rgba(236,72,153,0.15);color:#f472b6;}
.about-card-icon.green{background:rgba(34,197,94,0.15);color:var(--green);}
.about-card-icon.blue{background:rgba(59,130,246,0.15);color:#60a5fa;}
.about-card-icon svg{width:18px;height:18px;}
.about-card h3{font-family:'Syne',sans-serif;font-size:15px;font-weight:800;color:#fff;margin-bottom:6px;}
.about-card p{font-size:12.5px;color:var(--text2);line-height:1.65;}
.about-note{background:rgba(124,58,237,0.06);border:1px solid rgba(124,58,237,0.2);border-radius:var(--radius-lg);padding:18px 22px;font-size:13px;color:var(--text2);line-height:1.75;display:flex;gap:12px;align-items:flex-start;}
.about-note-icon{flex-shrink:0;margin-top:2px;color:var(--accent2);}
.about-note-icon svg{width:15px;height:15px;}

/* SECTION HERO */
.section-hero{margin-bottom:36px;padding-bottom:30px;border-bottom:1px solid var(--border);}
.badge{display:inline-flex;align-items:center;gap:6px;font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:600;letter-spacing:1px;text-transform:uppercase;padding:4px 10px;border-radius:4px;margin-bottom:14px;}
.badge.purple{background:rgba(124,58,237,0.12);color:var(--accent2);border:1px solid rgba(124,58,237,0.3);}
.badge svg{width:11px;height:11px;}
.section-hero h1{font-family:'Syne',sans-serif;font-size:38px;font-weight:800;letter-spacing:-1px;line-height:1.1;color:#fff;margin-bottom:10px;}
.section-hero h1 em{color:var(--accent2);font-style:normal;}
.section-hero p{font-size:14px;color:var(--text2);max-width:600px;font-weight:300;}

/* SEARCH BAR */
.search-section{margin-bottom:36px;}
.search-label{font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--text3);margin-bottom:10px;}
.search-wrap{position:relative;}
.search-icon{position:absolute;left:14px;top:50%;transform:translateY(-50%);color:var(--text3);pointer-events:none;}
.search-icon svg{width:15px;height:15px;}
.search-input{width:100%;padding:12px 16px 12px 44px;background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);color:var(--text);font-family:'JetBrains Mono',monospace;font-size:13px;outline:none;transition:all var(--trans);}
.search-input:focus{border-color:var(--accent2);box-shadow:0 0 0 3px rgba(124,58,237,0.12);}
.search-input::placeholder{color:var(--text3);}
.search-results-count{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--text3);margin-top:9px;min-height:18px;}
.search-results-count span{color:var(--accent2);}

/* GAME BLOCKS */
.game-block{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-lg);margin-bottom:14px;overflow:hidden;transition:border-color var(--trans);}
.game-block:hover{border-color:var(--surface2);}
.game-block.hidden-search{display:none;}

.game-block-header{display:flex;align-items:center;gap:14px;padding:18px 22px;cursor:pointer;user-select:none;border-bottom:1px solid transparent;transition:background var(--trans);}
.game-block-header:hover{background:var(--surface);}
.game-block.open .game-block-header{border-bottom-color:var(--border);background:var(--surface);}

.game-block-num{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--text3);min-width:22px;}
.game-block-logo{width:54px;height:54px;border-radius:8px;overflow:hidden;display:flex;align-items:center;justify-content:center;background:var(--bg);flex-shrink:0;border:1px solid var(--border);}
.game-block-logo img{width:100%;height:100%;object-fit:contain;padding:4px;}
.game-block-info{flex:1;min-width:0;}
.game-block-title{font-family:'Syne',sans-serif;font-size:15px;font-weight:700;color:var(--text);}
.game-block-meta{font-size:11.5px;color:var(--text3);margin-top:3px;font-family:'JetBrains Mono',monospace;}
.game-block-tags{display:flex;gap:6px;flex-wrap:wrap;margin-top:7px;}
.gtag{font-size:10px;font-family:'JetBrains Mono',monospace;padding:2px 8px;border-radius:4px;background:rgba(124,58,237,0.1);color:var(--accent3);border:1px solid rgba(124,58,237,0.2);}
.gtag.pink{background:rgba(236,72,153,0.1);color:#f9a8d4;border-color:rgba(236,72,153,0.2);}
.gtag.green{background:rgba(34,197,94,0.1);color:#86efac;border-color:rgba(34,197,94,0.2);}

.game-block-right{display:flex;align-items:center;gap:12px;flex-shrink:0;margin-left:auto;}
.compat-badge{font-family:'JetBrains Mono',monospace;font-size:9.5px;font-weight:700;padding:3px 8px;border-radius:4px;background:rgba(34,197,94,0.1);color:var(--green);border:1px solid rgba(34,197,94,0.25);letter-spacing:0.05em;white-space:nowrap;}
.game-block-chevron{color:var(--text3);transition:transform var(--trans);}
.game-block-chevron svg{width:16px;height:16px;}
.game-block.open .game-block-chevron{transform:rotate(90deg);}

.game-block-body{display:none;padding:28px 24px;animation:bodyIn 0.2s ease;}
@keyframes bodyIn{from{opacity:0;transform:translateY(-4px)}to{opacity:1;transform:none}}
.game-block.open .game-block-body{display:block;}

/* GAME DETAIL */
.game-detail-grid{display:grid;grid-template-columns:1fr 268px;gap:28px;}
.game-logo-big{width:100%;border-radius:12px;overflow:hidden;background:var(--bg);border:1px solid var(--border);margin-bottom:20px;display:flex;align-items:center;justify-content:center;padding:20px 24px;min-height:150px;}
.game-logo-big img{max-width:100%;max-height:150px;object-fit:contain;}
.game-desc{font-size:13.5px;color:var(--text2);line-height:1.75;margin-bottom:22px;font-weight:300;}
.game-features-title{font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--text3);margin-bottom:12px;}
.game-feature-list{display:flex;flex-direction:column;gap:8px;}
.game-feature{display:flex;align-items:flex-start;gap:10px;font-size:13px;color:var(--text2);}
.game-feature-dot{width:6px;height:6px;border-radius:50%;background:var(--accent2);flex-shrink:0;margin-top:6px;box-shadow:0 0 6px rgba(168,85,247,0.5);}

/* DL BOX */
.dl-box{background:var(--bg);border:1px solid rgba(124,58,237,0.35);border-radius:var(--radius-lg);padding:22px;margin-bottom:14px;position:relative;overflow:hidden;}
.dl-box::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--accent),var(--accent2));}
.dl-size{font-family:'JetBrains Mono',monospace;font-size:26px;font-weight:700;color:var(--accent2);text-shadow:0 0 20px rgba(168,85,247,0.4);margin-bottom:4px;}
.dl-size-label{font-size:11px;color:var(--text3);margin-bottom:16px;}
.dl-compat-row{display:flex;align-items:center;gap:7px;font-size:11.5px;color:var(--green);margin-bottom:5px;}
.dl-compat-dot{width:6px;height:6px;border-radius:50%;background:var(--green);box-shadow:0 0 6px rgba(34,197,94,0.6);}
.btn-dl{width:100%;padding:12px 16px;margin-top:14px;background:linear-gradient(135deg,var(--accent),var(--accent2));border-radius:var(--radius);color:#fff;font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:700;letter-spacing:0.15em;display:flex;align-items:center;justify-content:center;gap:8px;cursor:pointer;transition:all var(--trans);text-decoration:none;box-shadow:0 4px 20px rgba(124,58,237,0.35);}
.btn-dl:hover{transform:translateY(-2px);box-shadow:0 8px 32px rgba(124,58,237,0.55);}
.btn-dl svg{width:14px;height:14px;}

.info-box{background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-lg);padding:16px;}
.info-row{display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid rgba(42,31,74,0.5);font-size:12px;}
.info-row:last-child{border-bottom:none;}
.info-key{color:var(--text3);}
.info-val{color:var(--text);font-weight:500;}
.info-val.purple{color:var(--accent2);}
.info-val.green{color:var(--green);}

.no-results{display:none;text-align:center;padding:48px 24px;font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--text3);letter-spacing:0.1em;}
.no-results.show{display:block;}
.no-results svg{width:32px;height:32px;margin:0 auto 14px;display:block;opacity:0.25;}

/* TOAST */
#toast-wrap{position:fixed;bottom:24px;right:24px;display:flex;flex-direction:column;gap:8px;z-index:9000;}
.toast{background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius);padding:11px 16px;font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--text);animation:toastIn 0.3s ease;display:flex;align-items:center;gap:10px;box-shadow:0 8px 32px rgba(0,0,0,0.4);min-width:220px;}
.toast.purple{border-left:3px solid var(--accent2);}
.toast svg{width:13px;height:13px;flex-shrink:0;}
@keyframes toastIn{from{opacity:0;transform:translateX(20px)}to{opacity:1;transform:none}}
@keyframes toastOut{to{opacity:0;transform:translateX(20px)}}

/* MOBILE OVERLAY */
#sb-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:190;backdrop-filter:blur(2px);}
#sb-overlay.open{display:block;}

@media(max-width:860px){.game-detail-grid{grid-template-columns:1fr;}.about-cards{grid-template-columns:1fr;}}
@media(max-width:768px){
  #sidebar{transform:translateX(-100%);}
  #sidebar.open{transform:translateX(0);}
  #main{margin-left:0;}
  #content{padding:28px 20px;}
  #hamburger{display:flex;}
  .home-hero h1{font-size:38px;}
  .section-hero h1{font-size:26px;}
  .game-block-right{flex-direction:column;align-items:flex-end;gap:6px;}
}
</style>
</head>
<body>

