<script>
const PAGES = {
  home:  { el:'page-home',  sb:'sb-btn-home',  title:'Inicio',           root:'STRECH' },
  todos: { el:'page-todos', sb:'sb-btn-todos',  title:'Todos los juegos', root:'STRECH' },
  gta:   { el:'page-gta',   sb:'sb-btn-gta',   title:'GTA',              root:'STRECH' },
};

function nav(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.sb-nav-btn').forEach(b => b.classList.remove('active'));
  const cfg = PAGES[id];
  if (!cfg) return;
  document.getElementById(cfg.el).classList.add('active');
  if (cfg.sb) document.getElementById(cfg.sb).classList.add('active');
  document.getElementById('tb-root').textContent = cfg.root;
  document.getElementById('tb-page').textContent = cfg.title;
  window.scrollTo({top:0});
  closeSidebar();
}

function filterTodos(q) {
  const query = q.toLowerCase().trim();
  document.querySelectorAll('.todos-game-card').forEach(card => {
    const text = (card.dataset.search || '') + ' ' + (card.querySelector('.todos-card-title')?.textContent || '');
    card.classList.toggle('hidden-search', query && !text.toLowerCase().includes(query));
  });
}

function searchSidebar(q) {
  const query = q.toLowerCase().trim();
  const gtaBtn = document.getElementById('sb-btn-gta');
  const secTitle = document.querySelector('.sb-section-title.purple');
  if (!query) {
    if (gtaBtn) gtaBtn.style.display = '';
    if (secTitle) secTitle.style.display = '';
    return;
  }
  const gtaMatch = 'gta grand theft auto'.includes(query);
  if (gtaBtn) gtaBtn.style.display = gtaMatch ? '' : 'none';
  if (secTitle) secTitle.style.display = gtaMatch ? '' : 'none';
}

function toggleBlock(header) {
  const block  = header.parentElement;
  const page   = block.closest('.page');
  const isOpen = block.classList.contains('open');
  page.querySelectorAll('.game-block.open').forEach(b => b.classList.remove('open'));
  if (!isOpen) block.classList.add('open');
}

function openBlock(id) {
  const el = document.getElementById(id);
  if (!el) return;
  el.closest('.page').querySelectorAll('.game-block.open').forEach(b => b.classList.remove('open'));
  el.classList.add('open');
  setTimeout(() => {
    window.scrollTo({top: el.getBoundingClientRect().top + window.scrollY - 70, behavior:'smooth'});
  }, 30);
}

function filterGames(q) {
  const query   = q.toLowerCase().trim();
  const blocks  = document.querySelectorAll('#page-gta .game-block');
  let visible   = 0;
  blocks.forEach(b => {
    const text  = (b.dataset.search||'') + ' ' + (b.querySelector('.game-block-title')?.textContent||'');
    const match = !query || text.toLowerCase().includes(query);
    b.classList.toggle('hidden-search', !match);
    if (match) visible++;
  });
  const countEl = document.getElementById('searchCount');
  countEl.innerHTML = query
    ? `<span>${visible}</span> resultado${visible!==1?'s':''} para "<span>${q}</span>"`
    : '';
  document.getElementById('noResults').classList.toggle('show', visible === 0 && !!query);
}

function showToast(msg) {
  const wrap = document.getElementById('toast-wrap');
  const t    = document.createElement('div');
  t.className = 'toast purple';
  t.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>${msg}`;
  wrap.appendChild(t);
  setTimeout(() => {
    t.style.animation = 'toastOut 0.3s ease forwards';
    t.addEventListener('animationend', () => t.remove());
  }, 3500);
}

function toggleSidebar() {
  document.getElementById('sidebar').classList.toggle('open');
  document.getElementById('sb-overlay').classList.toggle('open');
}
function closeSidebar() {
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('sb-overlay').classList.remove('open');
}

// LOADER
(function() {
  const bar  = document.getElementById('ldBar');
  const msg  = document.getElementById('ldMsg');
  const msgs = ['INICIALIZANDO...','CARGANDO ACTIVOS...','VERIFICANDO ARCHIVOS...','SISTEMA LISTO'];
  let p = 0, mi = 0;
  const iv = setInterval(() => {
    p = Math.min(p + Math.random() * 16 + 5, 100);
    bar.style.width = p + '%';
    const ni = Math.floor(p / 100 * (msgs.length - 1));
    if (ni !== mi) { mi = ni; msg.textContent = msgs[mi]; }
    if (p >= 100) {
      clearInterval(iv);
      setTimeout(() => document.getElementById('loader').classList.add('gone'), 400);
    }
  }, 65);
})();
</script>
